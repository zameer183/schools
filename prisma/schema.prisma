generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  GRADED
}

enum NotificationType {
  SYSTEM
  ACADEMIC
  FINANCIAL
  ATTENDANCE
  MESSAGE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum TransactionType {
  CASH
  BANK_TRANSFER
  CARD
  ONLINE
}

enum LessonType {
  JUZZ
  SURAH
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  fullName       String
  role           UserRole
  phone          String?
  avatarUrl      String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?

  sentMessages     Message[]         @relation("MessageSender")
  receivedMessages MessageRecipient[]
  notifications    Notification[]
  files            FileAsset[]       @relation("Uploader")
}

model Student {
  id               String               @id @default(cuid())
  userId           String               @unique
  admissionNo      String               @unique
  dateOfBirth      DateTime?
  currentAddress   String?
  emergencyContact String?
  classId          String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  class        Class?               @relation(fields: [classId], references: [id])
  attendance   Attendance[]
  results      Result[]
  fees         Fee[]
  submissions  AssignmentSubmission[]
  progressLogs StudentProgress[]
  parentLinks  ParentStudent[]
  notifications Notification[]      @relation("StudentNotifications")
}

model Teacher {
  id             String        @id @default(cuid())
  userId         String        @unique
  employeeCode   String        @unique
  qualification  String?
  specialization String?
  joiningDate    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  classAssignments TeacherClass[]
  subjects         Subject[]
  attendanceMarked Attendance[]         @relation("AttendanceMarker")
  exams            Exam[]
  assignments      Assignment[]
  progressLogs     StudentProgress[]
}

model Parent {
  id              String          @id @default(cuid())
  userId          String          @unique
  occupation      String?
  relationToChild String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children   ParentStudent[]
  payments   Payment[]
}

model ParentStudent {
  parentId   String
  studentId  String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
}

model Class {
  id          String        @id @default(cuid())
  name        String
  section     String
  roomNo      String?
  academicYear String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  students     Student[]
  subjects     Subject[]
  teacherLinks TeacherClass[]
  attendance   Attendance[]
  assignments  Assignment[]
  exams        Exam[]
  progressLogs StudentProgress[]

  @@unique([name, section, academicYear])
}

model StudentProgress {
  id           String     @id @default(cuid())
  date         DateTime
  classId      String
  studentId    String
  teacherId    String
  lessonType   LessonType
  juzzNumber   Int?
  lessonNumber Int
  ayahFrom     Int?
  ayahTo       Int?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  class        Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([classId, date])
}

model TeacherClass {
  teacherId  String
  classId    String
  isClassLead Boolean @default(false)
  createdAt  DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([teacherId, classId])
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  classId     String
  teacherId   String?
  creditHours Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     Teacher?   @relation(fields: [teacherId], references: [id])
  exams       Exam[]
  assignments Assignment[]
  results     Result[]
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  classId     String
  markedById  String?
  date        DateTime
  status      AttendanceStatus
  remarks     String?
  createdAt   DateTime         @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedBy  Teacher? @relation("AttendanceMarker", fields: [markedById], references: [id])

  @@unique([studentId, date])
  @@index([classId, date])
}

model Exam {
  id            String   @id @default(cuid())
  title         String
  classId       String
  subjectId     String
  createdById   String
  examDate      DateTime
  totalMarks    Int
  passingMarks  Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdBy Teacher @relation(fields: [createdById], references: [id])
  results   Result[]
}

model Result {
  id          String   @id @default(cuid())
  examId      String
  studentId   String
  subjectId   String
  marksObtained Float
  grade       String
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model Fee {
  id            String        @id @default(cuid())
  studentId      String
  title          String
  dueDate        DateTime
  amount         Decimal       @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments  Payment[]
}

model Payment {
  id             String          @id @default(cuid())
  feeId           String
  parentId        String?
  amountPaid      Decimal         @db.Decimal(12, 2)
  method          TransactionType
  transactionRef  String?
  paidAt          DateTime        @default(now())
  createdAt       DateTime        @default(now())

  fee      Fee     @relation(fields: [feeId], references: [id], onDelete: Cascade)
  parent   Parent? @relation(fields: [parentId], references: [id])
}

model Assignment {
  id             String           @id @default(cuid())
  title          String
  description    String
  classId        String
  subjectId      String
  teacherId      String
  status         AssignmentStatus @default(DRAFT)
  dueDate        DateTime
  maxMarks       Int              @default(100)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  class        Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher      Teacher               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  files        FileAsset[]           @relation("AssignmentFiles")
  submissions  AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String?
  submittedAt   DateTime         @default(now())
  status        SubmissionStatus @default(SUBMITTED)
  marksObtained Float?
  feedback      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  files      FileAsset[] @relation("SubmissionFiles")

  @@unique([assignmentId, studentId])
}

model Message {
  id          String             @id @default(cuid())
  senderId    String
  subject     String
  body        String
  createdAt   DateTime           @default(now())

  sender      User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipients  MessageRecipient[]
}

model MessageRecipient {
  id          String   @id @default(cuid())
  messageId   String
  userId      String
  isRead      Boolean  @default(false)
  readAt      DateTime?

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  studentId   String?
  title       String
  body        String
  type        NotificationType  @default(SYSTEM)
  isRead      Boolean           @default(false)
  createdAt   DateTime          @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  student     Student?          @relation("StudentNotifications", fields: [studentId], references: [id])
}

model FileAsset {
  id             String   @id @default(cuid())
  uploadedById   String
  fileName       String
  originalName   String
  mimeType       String
  sizeInBytes    Int
  storagePath    String
  assignmentId   String?
  submissionId   String?
  createdAt      DateTime @default(now())

  uploadedBy     User                 @relation("Uploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  assignment     Assignment?          @relation("AssignmentFiles", fields: [assignmentId], references: [id])
  submission     AssignmentSubmission? @relation("SubmissionFiles", fields: [submissionId], references: [id])
}
